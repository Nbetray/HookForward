APP_NAME=hookforward

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

APP_ENV=development
APP_ADDR=:8080
# Backend public origin. GitHub callback will be:
# http://localhost:8080/api/v1/auth/github/callback
APP_PUBLIC_BASE_URL=http://localhost:8080
# Frontend origin used after GitHub OAuth completes.
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_ALLOWED_ORIGINS=http://localhost:5173
APP_MIGRATIONS_DIR=./migrations

POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/hookforward?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-me

# SMTP for verification emails. Use authenticated submission on port 587.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=hookforward

# GitHub OAuth App credentials.
# Homepage URL: http://localhost:5173
# Authorization callback URL: http://localhost:8080/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
